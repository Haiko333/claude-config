# ────── NVIDIA NIM ──────
# Get your key at: https://build.nvidia.com → API Keys
# Default model: qwen/qwen3-coder-480b-a35b-instruct
NVIDIA_NIM_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ────── OpenRouter ──────
# Get your key at: https://openrouter.ai/keys
# Default model: deepseek/deepseek-coder
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ────── DeepSeek ──────
# Get your key at: https://platform.deepseek.com/api_keys
# Default model: deepseek-coder
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ────── Ollama ──────
# Ollama runs locally — no API key required by default.
# Set this only if your Ollama instance requires authentication.
# Default base URL: http://localhost:11434/v1
OLLAMA_API_KEY=optional-auth-token